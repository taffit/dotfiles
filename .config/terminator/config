[global_config]
  focus = mouse
  enabled_plugins = ,
  suppress_multiple_term_dialog = True
  title_use_system_font = False
  title_font = Fira Mono Medium 9
[keybindings]
  zoom_in = None
  zoom_out = None
  zoom_normal = None
  go_next = <Primary><Shift><Super>j
  go_prev = <Primary><Shift><Super>k
  go_up = <Shift><Super>k
  go_down = <Shift><Super>j
  go_left = <Shift><Super>h
  go_right = <Shift><Super>l
  rotate_cw = None
  rotate_ccw = None
  split_horiz = <Primary><Shift>underscore
  split_vert = <Primary><Shift>bar
  close_term = <Primary><Shift>w
  toggle_scrollbar = None
  search = None
  close_window = <Primary><Shift>q
  move_tab_right = None
  move_tab_left = None
  scaled_zoom = None
  reset = None
  reset_clear = None
  hide_window = None
  group_all = None
  ungroup_all = None
  group_tab = None
  ungroup_tab = None
  broadcast_off = <Shift><Alt>q
  broadcast_group = <Shift><Alt>g
  broadcast_all = <Shift><Alt>e
  insert_number = None
  insert_padded = None
  layout_launcher = None
[profiles]
  [[default]]
    visible_bell = True
    background_color = "#282828"
    background_darkness = 0.9
    background_type = transparent
    cursor_color = "#aaaaaa"
    font = Fira Mono Medium 9
    foreground_color = "#ebdbb2"
    scrollbar_position = hidden
    scroll_on_output = True
    scrollback_lines = 10000
    palette = "#282828:#cc241d:#98971a:#d79921:#458588:#b16286:#689d6a:#a89984:#928374:#fb4934:#b8bb26:#fabd2f:#83a598:#d3869b:#8ec07c:#ebdbb2"
    use_system_font = False
    copy_on_selection = True
[layouts]
  [[default]]
    [[[child1]]]
      parent = window0
      profile = default
      type = Terminal
    [[[window0]]]
      parent = ""
      type = Window
[plugins]
